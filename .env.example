# ───────────────────────────────────────────────────────────────────────────
# Lumina LMS — Environment Variables
# Copy this file to `.env` and fill in the values. Never commit `.env`.
# ───────────────────────────────────────────────────────────────────────────

# ── Core ────────────────────────────────────────────────────────────────────
NODE_ENV=development
# Public base URL of the app (used in emails + auth callbacks)
APP_URL=http://localhost:3000

# ── Database (Neon / PostgreSQL) ─────────────────────────────────────────────
# Get a free serverless Postgres at https://neon.tech
DATABASE_URL=postgresql://user:password@host.neon.tech/lumina?sslmode=require

# ── Auth.js v5 ───────────────────────────────────────────────────────────────
# Generate one with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=replace-me-with-a-32-byte-random-secret
# Trust the host header behind a proxy (Vercel sets this automatically)
AUTH_TRUST_HOST=true

# ── Brevo Transactional Email ────────────────────────────────────────────────
# https://app.brevo.com/settings/keys/api
BREVO_API_KEY=
BREVO_SENDER_EMAIL=no-reply@yourlibrary.com
BREVO_SENDER_NAME=Lumina Library

# ── Cloudinary (cover & avatar uploads) ──────────────────────────────────────
# https://console.cloudinary.com/settings/api-keys
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# ── Library policy defaults (overridable in Settings) ────────────────────────
DEFAULT_LOAN_DAYS=14
DEFAULT_FINE_PER_DAY=0.50
DEFAULT_MAX_BORROW_LIMIT=5
